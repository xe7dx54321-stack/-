{
  "model_name": "campaign_score_v1",
  "model_version": "v1.0",
  "analysis_only": true,
  "not_betting_advice": true,
  "score_components": {
    "ev_weight": 0.25,
    "edge_weight": 0.15,
    "target_contribution_weight": 0.25,
    "odds_band_fit_weight": 0.15,
    "model_probability_weight": 0.10,
    "confidence_weight": 0.05,
    "data_quality_weight": 0.05
  },
  "penalties": {
    "negative_ev_penalty": 0.10,
    "very_low_confidence_penalty": 0.20,
    "probability_repaired_penalty": 0.05,
    "lottery_penalty_for_core": 1.00,
    "correct_score_core_penalty": 1.00,
    "missing_probability_penalty": 1.00
  },
  "candidate_tiers": {
    "value_candidate": {
      "min_campaign_score": 0.65,
      "requires_value_flag": true
    },
    "campaign_candidate": {
      "min_campaign_score": 0.45,
      "requires_value_flag": false
    },
    "attack_candidate": {
      "min_campaign_score": 0.35,
      "allowed_buckets": ["attack"]
    },
    "lottery_candidate": {
      "min_campaign_score": 0.20,
      "allowed_odds_bands": ["very_high", "lottery"],
      "allowed_buckets": ["attack"]
    },
    "watch_only": {
      "min_campaign_score": 0.0
    }
  }
}