{
  "model_name": "model_calibration_review_v1",
  "model_version": "v1.0",
  "analysis_only": true,
  "simulation_only": true,
  "not_betting_advice": true,
  "metrics": {
    "brier_score_enabled": true,
    "log_loss_enabled": true,
    "calibration_bins_enabled": true,
    "hit_rate_enabled": true,
    "simulated_return_enabled": true
  },
  "calibration_bins": [0.0, 0.1, 0.2, 0.35, 0.5, 0.65, 0.8, 0.9, 1.0],
  "min_sample_size_for_recommendation": 10,
  "small_sample_policy": "warn_only",
  "pending_policy": {
    "exclude_pending_from_realized_metrics": true,
    "include_pending_in_exposure_summary": true
  }
}
